{
  "data": {
    "period": "60d",
    "interval": "5m",
    "min_bars": 60,
    "correlation_lookback_bars": 60,
    "fetchable_only": true
  },
  "scanner": {
    "min_last_price": 5.0,
    "min_median_turnover": 2000000.0,
    "min_bars": 60,
    "regime_risk_on_breadth": 0.60,
