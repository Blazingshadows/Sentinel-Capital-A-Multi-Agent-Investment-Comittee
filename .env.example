GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NEWSAPI_KEY=
DATABASE_URL=sqlite:///./data/committee.db

# ICICI Direct Breeze API (market data). breeze_api_key/secret come from your
# app at https://api.icicidirect.com/apiuser/home (View Apps). session_token
# is the daily api_session value from the redirect URL after logging in there
# -- SEBI requires this manual login every trading day; it expires at
# midnight, so paste a fresh value each morning before the market opens.
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_SESSION_TOKEN=

# Comma-separated exact origins for a deployed frontend, e.g.
# https://committee.example.com,https://staging.committee.example.com
# Leave empty for local dev -- api/main.py falls back to a localhost-only
# regex so the Vite dev server (any port) can reach the API without this set.
CORS_ALLOWED_ORIGINS=
