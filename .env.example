# ICICI Direct Breeze API (market data). breeze_api_key/secret come from your
# app at https://api.icicidirect.com/apiuser/home (View Apps). session_token
# is the daily api_session value from the redirect URL after logging in there
# -- SEBI requires this manual login every trading day; it expires at
# midnight, so paste a fresh value each morning before the market opens.
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_SESSION_TOKEN=
